From 0bb5972e060f1a1bef6eb99a025e841553f91de6 Mon Sep 17 00:00:00 2001
From: Sam Talbot <sam.talbot@consult.red>
Date: Mon, 8 Jan 2024 10:11:50 +0000
Subject: [PATCH 1/3] 1. Only check for image manifests when using images.  2.
 fix cthulhu_extract_bundle_wrapper

---
 src/cthulhu_ctr_create.c | 15 +++++++--------
 1 file changed, 7 insertions(+), 8 deletions(-)

diff --git a/src/cthulhu_ctr_create.c b/src/cthulhu_ctr_create.c
index 3c8aca5..e9fe062 100644
--- a/src/cthulhu_ctr_create.c
+++ b/src/cthulhu_ctr_create.c
@@ -464,11 +464,6 @@ static cthulhu_action_res_t cthulhu_build_container(cthulhu_notif_data_t* notif_
         cthulhu_config->sandbox = strdup("");
         cthulhu_config->cgroup_dir = strdup("");
     }
-    image_manifest = cthulhu_get_image_manifest_schema_from_image(bundle_location, bundle_version, app_data->image_location, app_data->blob_location);
-    if(image_manifest == NULL) {
-        NOTIF_FAILED(notif_data, tr181_fault_request_denied, "Could not find Image Manifest for image %s:%s", bundle_name, bundle_version);
-        goto exit;
-    }
 
     if(asprintf(&cthulhu_config->rootfs, "%s/%s", app_data->rootfs_location, ctr_id) < 0) {
         SAH_TRACEZ_ERROR(ME, "CTR[%s]: Could not allocate the rootfs string", ctr_id);
@@ -498,6 +493,12 @@ static cthulhu_action_res_t cthulhu_build_container(cthulhu_notif_data_t* notif_
 
         when_failed_log(lcm_worker_add_task(cthulhu_get_worker(), task, false), error);
     } else {
+        image_manifest = cthulhu_get_image_manifest_schema_from_image(bundle_location, bundle_version, app_data->image_location, app_data->blob_location);
+        if(image_manifest == NULL) {
+            NOTIF_FAILED(notif_data, tr181_fault_request_denied, "Could not find Image Manifest for image %s:%s", bundle_name, bundle_version);
+            goto exit;
+        }
+
         cthulhu_update_manifest_params(ctr_id, image_manifest);
         cthulhu_plugin_ctr_create(ctr_id, metadata, image_manifest);
         cthulhu_ctr_apply_metadata(ctr_id, metadata);
@@ -776,7 +777,6 @@ exit:
 
 static int cthulhu_extract_bundle_wrapper(UNUSED lcm_worker_t* worker, amxc_var_t* var, UNUSED int rc) {
     int retval = -1;
-    amxc_string_t target;
     const char* bundle_name = GET_CHAR(var, BUNDLE_NAME);
     const char* bundle_extract_location = GET_CHAR(var, BUNDLE_EXTRACT_LOCATION);
     const char* bundle_location = GET_CHAR(var, BUNDLE_LOCATION);
@@ -786,10 +786,9 @@ static int cthulhu_extract_bundle_wrapper(UNUSED lcm_worker_t* worker, amxc_var_
         goto exit;
     }
 
-
+    retval = 0;
 exit:
     amxc_var_delete(&var);
-    amxc_string_clean(&target);
     return retval;
 }
 
-- 
2.25.1

