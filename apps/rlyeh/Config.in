config PACKAGE_rlyeh
    tristate
    select SAH_SERVICES_RLYEH

if PACKAGE_rlyeh

menu "Select rlyeh build options"
    depends on PACKAGE_rlyeh

config SAH_SERVICES_RLYEH
    bool "Build Rlyeh"
    default y

config SAH_SERVICES_RLYEH_ORDER
    int "Rlyeh plugin start up order"
    default 90

config SAH_SERVICES_RLYEH_PROCD_SUPPORT
    bool "Installs procd init script in stead of the default init script"
    default PACKAGE_procd

endmenu

endif
